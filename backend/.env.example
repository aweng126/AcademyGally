# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/academy.db
# For PostgreSQL (future): DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Storage paths (inside Docker container, bound to ./data on host) ──────────
FIGURES_DIR=/data/figures
PDFS_DIR=/data/pdfs

# ── CORS (comma-separated, defaults to localhost:3000 + 127.0.0.1:3000) ───────
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ══════════════════════════════════════════════════════════════════════════════
# VLM Provider — choose ONE of the options below
# ══════════════════════════════════════════════════════════════════════════════

# ── Option A: Anthropic Claude (default) ─────────────────────────────────────
VLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
VLM_MODEL=claude-opus-4-6
# Other Claude models: claude-sonnet-4-6, claude-haiku-4-5-20251001

# ── Option B: GLM (智谱AI) ────────────────────────────────────────────────────
# VLM_PROVIDER=openai_compatible
# VLM_API_KEY=<your zhipuai key>
# VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# VLM_MODEL=glm-4v-plus         # vision model (for image analysis)
# VLM_TEXT_MODEL=glm-4-plus     # text model (for abstract analysis)

# ── Option C: OpenAI ─────────────────────────────────────────────────────────
# VLM_PROVIDER=openai_compatible
# VLM_API_KEY=sk-...
# VLM_BASE_URL=https://api.openai.com/v1
# VLM_MODEL=gpt-4o
# VLM_TEXT_MODEL=gpt-4o-mini

# ── Option D: DeepSeek ───────────────────────────────────────────────────────
# VLM_PROVIDER=openai_compatible
# VLM_API_KEY=<your deepseek key>
# VLM_BASE_URL=https://api.deepseek.com/v1
# VLM_MODEL=deepseek-chat
# VLM_TEXT_MODEL=deepseek-chat

# ── Option E: Ollama (local, no API key needed) ───────────────────────────────
# VLM_PROVIDER=openai_compatible
# VLM_API_KEY=ollama
# VLM_BASE_URL=http://host.docker.internal:11434/v1
# VLM_MODEL=llava:13b
# VLM_TEXT_MODEL=llama3.1:8b
